@using sos100_bibliotek.Controllers
@model IEnumerable<sos100_bibliotek.Models.BookCatalogue>
@{
    ViewData["Title"] = "Katalog";
}
<link rel="stylesheet" href="~/css/BookCatalogue.css" asp-append-version="true"/>
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success" style="padding: 15px; background-color: #d4edda; color: #155724; border: 1px solid #c3e6cb; border-radius: 4px; margin-bottom: 20px;">
        @TempData["SuccessMessage"]
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger" style="padding: 15px; background-color: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; border-radius: 4px; margin-bottom: 20px;">
        @TempData["ErrorMessage"]
    </div>
}

<main class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Bokkatalog</h1>
        @if (Context.Session.GetString("Username") == "admin")
        {
            <a asp-action="CreateBook" class="btn btn-success">Lägg till en bok</a>
        }
    </div>
    @* Grid-system: row-cols-md-3 gör att det blir 3 kort per rad *@
    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var Books in Model)
        { 
            <div class="col">
                <div class="card h-100 shadow-sm border-0 bg-light p-3">
                    <div class="card-body">
                        <h5 class="card-title text-primary">@Books.Title</h5>
                        <p class="mb-1 text-muted"><strong>Författare:</strong> @Books.Author</p>
                        <hr />
                        <div class="small text-secondary">
                            <p class="mb-1"><strong>Utgiven:</strong> @Books.Year</p>
                            <p class="mb-1"><strong>Antal sidor:</strong> @Books.Pages</p>
                            <p class="mb-1"><strong>Språk:</strong> @Books.Language</p>
                            <p class="mb-1"><strong>Förlag:</strong> @Books.Publisher</p>
                            <p class="mb-1"><strong>ISBN:</strong> @Books.Isbn</p>
                        </div>
                    </div>

                    <div class="card-footer bg-transparent border-0 mt-2">
                        @if (Context.Session.GetString("Username") != null)
                        {
                            <div class="d-grid gap-2">
                                <form asp-controller="Home" asp-action="BorrowBook" method="post">
                                    <input type="hidden" name="bookId" value="@Books.Id" />
                                    <input type="hidden" name="bookTitle" value="@Books.Title" />
                                    <button class="btn btn-primary w-100 LoanKnapp" type="submit">Låna boken</button>
                                </form>
                            
                                <a asp-controller="Reservations" asp-action="Index" class="btn btn-primary w-100">Reservera boken</a>
                            </div>
                        }
                        else
                        {
                            <p class="text-center text-muted small italic">Logga in för att låna</p>
                        }

                        @if (Context.Session.GetString("Username") == "admin")
                        { 
                            <div class="d-flex gap-2 mt-2">
                                <a asp-action="EditBook" asp-route-id="@Books.Id" class="btn btn-sm btn-outline-secondary w-50 UpdateKnapp text-center">Redigera</a>

                                <form asp-action="DeleteBook" asp-route-id="@Books.Id" method="post" class="w-50">
                                    <button class="btn btn-sm btn-outline-danger w-100 DeleteKnapp" type="submit">Ta bort</button>
                                </form>
                            </div>
                        }
                    </div>
                </div> 
            </div> 
        }
    </div>
</main>