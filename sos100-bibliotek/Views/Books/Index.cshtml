@using sos100_bibliotek.Controllers
@model IEnumerable<sos100_bibliotek.Models.BookCatalogue>
@{
    ViewData["Title"] = "Katalog";
}
<link rel="stylesheet" href="~/css/BookCatalogue.css" asp-append-version="true"/>

<main>
    @if (Context.Session.GetString("Username") == "admin")
    {
        <a asp-action="CreateBook" class="CreateKnapp">Lägg till en bok</a>
    }

    <h1>Bokkatalog</h1>

    @* Bekräftelse / felmeddelande visas här efter lån *@
    @if (TempData["Message"] != null)
    {
        <p style="color: green; font-weight: bold;">@TempData["Message"]</p>
    }
    @if (TempData["Error"] != null)
    {
        <p style="color: red; font-weight: bold;">@TempData["Error"]</p>
    }

    <div class="Catalogue">
        @foreach (var Books in Model)
        { 
            <div class="Books">
                <p><strong>Titel:</strong> @Books.Title</p>
                <p><strong>Författare:</strong> @Books.Author</p>
                <p><strong>Utgiven:</strong> @Books.Year</p>
                <p><strong>Antal sidor:</strong> @Books.Pages</p>
                <p><strong>Språk:</strong> @Books.Language</p>
                <p><strong>Förlag:</strong> @Books.Publisher</p>
                <p><strong>ISBN:</strong> @Books.Isbn</p>

                @* Knappen är dold om användaren inte är inloggad *@
                @if (Context.Session.GetString("Username") != null)
                {
                    <form asp-controller="Home" asp-action="BorrowBook" method="post">
                        <input type="hidden" name="bookId" value="@Books.Id" />
                        <input type="hidden" name="bookTitle" value="@Books.Title" />
                        <button class="LoanKnapp" type="submit">Låna boken</button>
                    </form>
                }
                else
                {
                    <p style="color: gray; font-style: italic;">Logga in för att låna</p>
                }

                @if (Context.Session.GetString("Username") == "admin")
                { 
                    <a asp-action="EditBook" asp-route-id="@Books.Id" class="UpdateKnapp">Redigera</a>

                    <form asp-action="DeleteBook" asp-route-id="@Books.Id" method="post">
                        <button class="DeleteKnapp" type="submit">Ta bort boken</button>
                    </form>
                }
            </div> 
        }
    </div>
</main>