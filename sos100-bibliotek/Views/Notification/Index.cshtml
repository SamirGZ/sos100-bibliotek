@model List<sos100_bibliotek.Services.NotificationDto>

@{
    var role = Context.Session.GetString("Role") ?? "user";
    var currentUserId = Context.Session.GetInt32("UserId");
    var isAdmin = role == "admin";

    // FILTRERING: Om man inte är admin, visa bara notiser som matchar ens UserId
    var displayList = isAdmin 
        ? Model.OrderByDescending(x => x.CreatedAt).ToList() 
        : Model.Where(x => x.UserId == currentUserId).OrderByDescending(x => x.CreatedAt).ToList();
}

<div class="content-wrapper" style="padding: 2rem;">
    <h2>@(isAdmin ? "Hantera Notifikationer" : "🔔 Mina Notifikationer")</h2>

    @if (!displayList.Any())
    {
        <div class="alert alert-info">Inga notifikationer just nu.</div>
    }
    else
    {
        <div class="list-group mt-3">
            @foreach (var n in displayList)
            {
                <div class="list-group-item d-flex justify-content-between align-items-center">
                    <div>
                        <p class="mb-1 @(n.IsRead ? "text-muted" : "fw-bold")">@n.Message</p>
                        <small class="text-muted">
                            @(isAdmin ? $"Användare: {n.UserId} | " : "") @n.CreatedAt.ToString("g")
                        </small>
                    </div>
                    <form asp-action="Delete" method="post">
                        <input type="hidden" name="id" value="@n.Id" />
                        <button type="submit" class="btn btn-sm btn-outline-danger">🗑 Ta bort</button>
                    </form>
                </div>
            }
        </div>
    }
</div>