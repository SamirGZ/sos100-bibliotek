@model List<sos100_bibliotek.Services.NotificationDto>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-bell"></i> Notifikationer</h2>
        <span class="badge bg-primary">Totalt: @Model.Count</span>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-light border shadow-sm text-center py-5">
            <i class="bi bi-inbox fs-1 text-muted"></i>
            <p class="mt-2 text-muted">Du har inga notifikationer just nu.</p>
        </div>
    }
    else
    {
        <div class="list-group">
            @foreach (var n in Model)
            {
                <div class="list-group-item list-group-item-action shadow-sm mb-3 border-0 rounded @(n.IsRead ? "opacity-75" : "border-start border-primary border-4")">
                    <div class="d-flex w-100 justify-content-between align-items-start">
                        <div class="ms-2 me-auto">
                            <div class="fw-bold @(n.IsRead ? "text-muted" : "text-dark")">
                                @n.Message
                            </div>
                            <small class="text-muted">
                                <i class="bi bi-person"></i> @(string.IsNullOrEmpty(n.Username) ? "Okänd" : n.Username) 
                                <span class="mx-2">|</span> 
                                <i class="bi bi-clock"></i> @n.CreatedAt.ToString("g")
                            </small>
                        </div>
                        
                        <div class="btn-group ms-3">
                            @if (!n.IsRead)
                            {
                                <form asp-action="MarkAsRead" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@n.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-success border-0" title="Markera som läst">
                                        <i class="bi bi-check2-circle"></i>
                                    </button>
                                </form>
                            }
                            <form asp-action="Delete" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@n.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger border-0" onclick="return confirm('Ta bort notis?')" title="Radera">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>