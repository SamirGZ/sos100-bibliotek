@model List<sos100_bibliotek.Services.NotificationDto>
@{
    var currentUserId = Context.Session.GetInt32("UserId");
    var isAdmin = string.Equals(Context.Session.GetString("Role"), "admin", StringComparison.OrdinalIgnoreCase)
                  || string.Equals(Context.Session.GetString("Username"), "admin", StringComparison.OrdinalIgnoreCase);
}

<div class="content-wrapper" style="padding: 2rem;">
    <h2>@(isAdmin ? "Hantera notifikationer" : "Mina notifikationer")</h2>

    @if (isAdmin)
    {
        <form asp-controller="Notification" asp-action="CheckOverdueLoans" method="post" class="mb-3">
            <button type="submit" class="btn btn-warning">
                Klicka här för att skicka automatiska påminnelser (försenade lån)
            </button>
        </form>
    }

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success">@TempData["Message"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }
    @* Bakåtkompatibilitet om någon kod sätter gamla nycklar *@
    @if (TempData["NotificationMsg"] != null)
    {
        <div class="alert alert-success">@TempData["NotificationMsg"]</div>
    }
    @if (TempData["NotificationError"] != null)
    {
        <div class="alert alert-danger">@TempData["NotificationError"]</div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-info">Inga notifikationer just nu.</div>
    }
    else
    {
        <div class="list-group mt-3">
            @foreach (var n in Model)
            {
                <div class="list-group-item d-flex justify-content-between align-items-center">
                    <div>
                        <p class="mb-1 @(n.IsRead ? "text-muted" : "fw-bold")">@n.Message</p>
                        <small class="text-muted">
                            @(isAdmin ? $"Användare: {n.UserId} ({n.Username}) | " : "")@n.CreatedAt.ToString("g")
                            @if (n.IsRead && !isAdmin)
                            {
                                <span class="text-success ms-2">Läst</span>
                            }
                        </small>
                    </div>
                    <div class="d-flex gap-2">
                        @if (!n.IsRead && !isAdmin)
                        {
                            <form asp-controller="Notification" asp-action="MarkAsRead" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@n.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-success">Markera som läst</button>
                            </form>
                        }
                        <form asp-controller="Notification" asp-action="Delete" method="post" class="d-inline"
                              onsubmit="return confirm('Ta bort den här notisen?');">
                            <input type="hidden" name="id" value="@n.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-danger">Ta bort</button>
                        </form>
                    </div>
                </div>
            }
        </div>
    }
</div>
