@model sos100_bibliotek.Models.ReservationViewModel
@{
    ViewData["Title"] = "Ny reservation";
}
<link rel="stylesheet" href="~/css/reservations.css" asp-append-version="true"/>

<div class="reservation-page">
    <div class="reservation-card">
        <div class="page-header">
            <div>
                <span class="page-label">Bibliotekssystem</span>
                <h1>Ny reservation</h1>
                <p>
                    Samma upplägg som reservationlistan: användar-ID ska finnas i UserAPI och bok-ID i katalogen.
                </p>
            </div>
            <a asp-action="Index" class="create-btn create-btn--ghost">Tillbaka till listan</a>
        </div>

        <form asp-action="Create" method="post" class="reservation-form">
            <div class="form-group">
                <label asp-for="ItemId">Bok-ID</label>
                <input asp-for="ItemId" class="form-control" type="number" min="1" required/>
                <p class="form-hint">ID från katalogen (samma som i boklistan).</p>
            </div>

            <div class="form-group">
                <label asp-for="UserId">Användar-ID</label>
                <input asp-for="UserId" class="form-control" type="number" min="1" required/>
                <p class="form-hint">ID från UserAPI (samma som användaren får vid inloggning).</p>
            </div>

            <div class="form-group">
                <label asp-for="Status">Status</label>
                <input asp-for="Status" class="form-control" value="Active"/>
            </div>

            <div class="form-actions">
                <button type="submit" class="save-btn">Spara reservation</button>
                <a asp-action="Index" class="back-btn">Avbryt</a>
            </div>
        </form>
    </div>
</div>
