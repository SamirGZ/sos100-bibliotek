@using sos100_bibliotek.Helpers
@model List<sos100_bibliotek.Models.ReservationViewModel>
@{
    var isAdmin = ViewBag.IsAdmin != null && (bool)ViewBag.IsAdmin;
    ViewData["Title"] = isAdmin ? "Alla reservationer" : "Mina reservationer";
}
<link rel="stylesheet" href="~/css/reservations.css" asp-append-version="true"/>

@if (TempData["SuccessMessage"] != null)
{
    <div class="reservation-alert reservation-alert--success">
        @TempData["SuccessMessage"]
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="reservation-alert reservation-alert--error">
        @TempData["ErrorMessage"]
    </div>
}

<div class="reservation-page">
    <div class="reservation-card">
        <div class="page-header">
            <div>
                <span class="page-label">Bibliotekssystem</span>
                <h1>@(isAdmin ? "Alla reservationer" : "Mina reservationer")</h1>
                <p>
                    @(isAdmin
                        ? "Översikt över alla reservationer. Tid visas i svensk lokal tid."
                        : "Dina reservationer. Tid visas i svensk lokal tid.")
                </p>
            </div>

            @if (isAdmin)
            {
                <a asp-controller="Reservations" asp-action="Create" class="create-btn">Ny reservation</a>
            }
        </div>

        @if (Model == null || !Model.Any())
        {
            <div class="reservation-empty">
                <h3>Inga reservationer ännu</h3>
                <p>
                    @(isAdmin
                        ? "Det finns inga registrerade reservationer."
                        : "Du har inga reservationer just nu.")
                </p>
            </div>
        }
        else
        {
            <div class="table-wrapper">
                <table class="reservation-table">
                    <thead>
                    <tr>
                        <th>Nr</th>
                        @if (isAdmin)
                        {
                            <th>Användare</th>
                        }
                        <th>Bok</th>
                        <th>Författare</th>
                        <th>Datum &amp; tid</th>
                        <th>Status</th>
                        <th></th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var reservation in Model)
                    {
                        var swedishStatus = reservation.Status == "Cancelled" ? "Avbokad" : "Aktiv";

                        <tr>
                            <td><strong>#@reservation.Id</strong></td>
                            @if (isAdmin)
                            {
                                <td>
                                    <span class="text-break">@(string.IsNullOrEmpty(reservation.UserName) ? $"id {reservation.UserId}" : reservation.UserName)</span>
                                </td>
                            }
                            <td>@(string.IsNullOrEmpty(reservation.BookTitle) ? $"Bok #{reservation.ItemId}" : reservation.BookTitle)</td>
                            <td>@(string.IsNullOrEmpty(reservation.Author) ? "—" : reservation.Author)</td>
                            <td class="text-nowrap">@SwedenTime.FormatStockholm(reservation.ReservationDate)</td>
                            <td>
                                <span class="status-badge @(reservation.Status == "Cancelled" ? "cancelled" : "active")">
                                    @swedishStatus
                                </span>
                            </td>
                            <td>
                                <form asp-action="Delete" method="post" class="m-0">
                                    <input type="hidden" name="id" value="@reservation.Id"/>
                                    <button type="submit" class="delete-btn">Ta bort</button>
                                </form>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
