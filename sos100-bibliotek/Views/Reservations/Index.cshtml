@model List<sos100_bibliotek.Models.ReservationViewModel>

@{
    var isAdmin = ViewBag.IsAdmin != null && (bool)ViewBag.IsAdmin;
    ViewData["Title"] = isAdmin ? "Alla reservationer" : "Mina reservationer";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success" style="max-width: 980px; margin: 20px auto 0 auto; padding: 12px; background-color: #d4edda; color: #155724; border-radius: 8px;">
        @TempData["SuccessMessage"]
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger" style="max-width: 980px; margin: 20px auto 0 auto; padding: 12px; background-color: #f8d7da; color: #721c24; border-radius: 8px;">
        @TempData["ErrorMessage"]
    </div>
}

<div class="reservation-page">
    <div class="reservation-card">
        <div class="page-header">
            <div>
                <span class="page-label">Bibliotekssystem</span>
                <h1>@(isAdmin ? "Alla reservationer" : "Mina reservationer")</h1>
                <p>
                    @(isAdmin
                        ? "Här kan du se alla registrerade reservationer i systemet."
                        : "Här kan du se dina aktuella reservationer och deras status.")
                </p>
            </div>

            @if (isAdmin)
            {
                <a asp-controller="Reservations" asp-action="Create" class="create-btn">Ny reservation</a>
            }
        </div>

        @if (Model == null || !Model.Any())
        {
            <div class="empty-state">
                <h3>Inga reservationer ännu</h3>
                <p>
                    @(isAdmin
                        ? "Det finns just nu inga registrerade reservationer."
                        : "Du har just nu inga registrerade reservationer.")
                </p>
            </div>
        }
        else
        {
            <div class="table-wrapper">
                <table class="reservation-table">
                    <thead>
                    <tr>
                        <th>Bokningsnummer</th>

                        @if (isAdmin)
                        {
                            <th>Användare</th> <!-- 🔥 ÄNDRAD -->
                        }

                        <th>Bok</th>
                        <th>Författare</th>
                        <th>Bokningsdatum</th>
                        <th>Status</th>
                        <th>Åtgärd</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var reservation in Model)
                    {
                        var swedishStatus = reservation.Status == "Cancelled" ? "Avbokad" : "Aktiv";

                        <tr>
                            <td>#@reservation.Id</td>

                            @if (isAdmin)
                            {
                                <td>@reservation.UserName</td> <!-- 🔥 FIX -->
                            }

                            <td>@reservation.BookTitle</td> <!-- 🔥 FIX -->
                            <td>@reservation.Author</td> <!-- 🔥 FIX -->

                            <td>@reservation.ReservationDate.ToString("yyyy-MM-dd HH:mm")</td>

                            <td>
                                <span class="status-badge @(reservation.Status == "Cancelled" ? "cancelled" : "active")">
                                    @swedishStatus
                                </span>
                            </td>

                            <td>
                                <form asp-action="Delete" method="post">
                                    <input type="hidden" name="id" value="@reservation.Id" />
                                    <button type="submit" class="delete-btn">Ta bort</button>
                                </form>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>